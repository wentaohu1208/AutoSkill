          0.5862068965517242,\n            0.49813218390804603,\n            0.49985632183908046,\n            0.5948275862068966,\n        ],\n        \"Qwen3-32B\": [\n            0.10014367816091954,\n            0.6053160919540229,\n            0.5964080459770116,\n            0.40761494252873565,\n            0.7977011494252874,\n        ],\n        \"Timer-LM\": [\n            0.6043103448275863,\n            0.8081896551724138,\n            0.805890804597701,\n            0.8053160919540229,\n            0.7001436781609195,\n        ],\n    },\n    \"Random Acts of Pizza\": {\n        \"DeepSeek-V3.2-Chat\": [\n            0.6129310344827585,\n            0.40804597701149425,\n            0.8137931034482759,\n            0.7948275862068965,\n            0.8011494252873562,\n        ],\n        \"GPT-5.1(medium)\": [\n            0.0,\n            0.714500860585198,\n            0.7248278829604131,\n            0.692340791738382,\n            0.769104991394148,\n        ],\n        \"Gemini 2.5 pro\": [\n            0.7346170395869192,\n            0.7427925989672977,\n            0.7557013769363167,\n            0.7359079173838209,\n            0.7596815834767643,\n        ],\n        \"Qwen3-8B\": [\n            0.47332185886402756,\n            0.19944061962134252,\n            0.19061962134251292,\n            0.3783347676419966,\n            0.18943631669535285,\n        ],\n        \"Qwen3-14B\": [\n            0.47590361445783136,\n            0.6668459552495697,\n            0.6480206540447505,\n            0.5783132530120483,\n            0.6643717728055077,\n        ],\n        \"Qwen3-32B\": [\n            0.554539586919105,\n            0.5694922547332186,\n            0.47106282271944916,\n            0.6828743545611016,\n            0.6723321858864028,\n        ],\n        \"Timer-LM\": [\n            0.7600043029259897,\n            0.7615103270223752,\n            0.7620481927710843,\n            0.7625860585197934,\n            0.7603270223752152,\n        ],\n    },\n    \"Detecting Insults\": {\n        \"DeepSeek-V3.2-Chat\": [\n            0.8301851152247828,\n            0.8187570834907443,\n            0.8029845107669059,\n            0.8318851530034,\n            0.6140914242538723,\n        ],\n        \"GPT-5.1(medium)\": [\n            0.6224027200604458,\n            0.8273517189270873,\n            0.8245183226293917,\n            0.8372686059690215,\n            0.8402908953532301,\n        ],\n        \"Gemini 2.5 pro\": [\n            0.41589535323007176,\n            0.824943332074046,\n            0.8448243294295429,\n            0.8337268605969022,\n            0.8380241783150736,\n        ],\n        \"Qwen3-8B\": [\n            0.6228749527767283,\n            0.5212976955043445,\n            0.4169342652058935,\n            0.5174253872308273,\n            0.5148753305629014,\n        ],\n        \"Qwen3-14B\": [\n            0.6238194182092937,\n            0.7272383830751794,\n            0.7214299206649036,\n            0.7271911598035511,\n            0.728088401964488,\n        ],\n        \"Qwen3-32B\": [\n            0.5113808084624103,\n            0.5042500944465433,\n            0.5116641480921799,\n            0.6145636569701549,\n            0.7171798262183604,\n        ],\n        \"Timer-LM\": [\n            0.8379769550434456,\n            0.838968643747639,\n            0.8409520211560259,\n            0.8409520211560259,\n            0.8409520211560259,\n        ],\n    },\n}\n\ntasks = [\"Leaf Classification\", \"Spaceship Titanic\", \"Random Acts of Pizza\", \"Detecting Insults\"]\n\n# --- 2.1 将 0~1 之间的小数统一转换为百分制 ---\n# 说明：原始表里有两种尺度：部分是 0.x（比例），部分已经是 80+ 的百分数。\n# 这里将所有 0 <= score <= 1 的数值乘以 100，统一成 [0, 100] 的分数。\nfor task, models in score_data.items():\n    for model_name, scores in models.items():\n        score_data[task][model_name] = [\n            (s * 100.0) if (0.0 <= s <= 1.0) else s\n            for s in scores\n        ]\n\n\n# --- 3. 视觉配置（颜色 / 线型 / marker） ---\nPAPER_COLORS = {\n    \"Timer-LM\": \"#D55E00\",      # 我们的模型：高亮橙红\n    \"1226_RL_200\": \"#CC79A7\",           # 我们的 RL 版本：洋红\n    \"DeepSeek-V3.2-Chat\": \"#56B4E9\",\n    \"GPT-5.1(medium)\": \"#009E73\",\n    \"Gemini 2.5 pro\": \"#E69F00\",\n    \"Qwen3-8B\": \"#0072B2\",\n    \"Qwen3-14B\": \"#F0E442\",\n    \"14B-V2\": \"#999999\",\n    \"Qwen3-32B\": \"#000000\",\n}\n\nLINESTYLES = {\n    \"Timer-LM\": \"--\",\n    \"1226_RL_200\": \"--\",\n    \"DeepSeek-V3.2-Chat\": \"-\",\n    \"GPT-5.1(medium)\": \"-\",\n    \"Gemini 2.5 pro\": \"-\",\n    \"Qwen3-8B\": \"-\",\n    \"Qwen3-14B\": \"-\",\n    \"14B-V2\": \"-.\",\n    \"Qwen3-32B\": \"-\",\n}\n\nMARKERS = {\n    \"Timer-LM\": \"D\",\n    \"1226_RL_200\": \"X\",\n    \"DeepSeek-V3.2-Chat\": \"o\",\n    \"GPT-5.1(medium)\": \"s\",\n    \"Gemini 2.5 pro\": \"^\",\n    \"Qwen3-8B\": \"v\",\n    \"Qwen3-14B\": \"P\",\n    \"14B-V2\": \"*\",\n    \"Qwen3-32B\": \"h\",\n}\n\n\n# --- 4. 绘图 ---\nfig, axes = plt.subplots(1, 4, figsize=(22, 5.2), sharex=True, sharey=False)\n\nlegend_handles = []\nlegend_labels = []\n\nfor idx, task in enumerate(tasks):\n    ax = axes[idx]\n    models = score_data.get(task, {})\n\n    # Y 轴网格\n    ax.grid(axis=\"y\", linestyle=\"--\", linewidth=0.6, alpha=0.3, zorder=0)\n\n    for model_name, scores in models.items():\n        color = PAPER_COLORS.get(model_name, \"gray\")\n        linestyle = LINESTYLES.get(model_name, \"-\")\n        marker = MARKERS.get(model_name, \"o\")\n\n        is_ours = (\n            \"Timer\" in model_name\n            or \"RL\" in model_name\n        )\n\n        # 对于长度不足 5 的序列，只用对应数量的 budget\n        x_vals = budgets[: len(scores)]\n        y_vals = scores\n\n        line, = ax.plot(\n            x_vals,\n            y_vals,\n            label=model_name,\n            color=color,\n            linestyle=linestyle,\n            marker=marker,\n            # 整体线条略加粗，RL_200 等我们的模型更粗、更大的点\n            markersize=9.5 if is_ours else 8.5,\n            linewidth=3.2 if is_ours else 2.5,\n            alpha=1.0 if is_ours else 0.85,\n            zorder=11 if is_ours else 6,\n            markeredgecolor=\"white\",\n            markeredgewidth=1.2 if is_ours else 0.9,\n        )\n\n        if idx == 0:\n            legend_handles.append(line)\n            legend_labels.append(model_name)\n\n    # 坐标轴与标题\n    ax.set_title(task, fontsize=18, fontweight=\"bold\", pad=10)\n    ax.set_xticks(budgets)\n    ax.set_xlim(0.9, 5.1)\n\n    # 百分制得分，保留 1 位小数\n    ax.yaxis.set_major_formatter(ticker.StrMethodFormatter('{x:.1f}'))\n\nfor ax in axes:\n    ax.set_xlabel(\"Time Budget (x)\", fontsize=18, fontweight=\"bold\", labelpad=8)\n\naxes[0].set_ylabel(\"Score (%)\", fontsize=18, fontweight=\"bold\", labelpad=8)\n\n\n# --- 5. 全局图例 ---\nfig.legend(\n    legend_handles,\n    legend_labels,\n    loc=\"lower center\",\n    ncol=4,\n    frameon=False,\n    bbox_to_anchor=(0.5, -0.06),\n    handlelength=3.0,\n    handletextpad=0.6,\n    columnspacing=2.5,\n    prop={\"size\": 16},\n)\n\n\n# --- 6. 布局与保存 ---\nplt.tight_layout()\nplt.subplots_adjust(bottom=0.24, wspace=0.25)\n\noutput_png = \"/mnt/shared-storage-user/llmbr-share/mayichuan/2025_Q4/Timely_Reasoner/Paper_Writing/ml_scaling_curve.png\"\noutput_pdf = \"/mnt/shared-storage-user/llmbr-share/mayichuan/2025_Q4/Timely_Reasoner/Paper_Writing/ml_scaling_curve.pdf\"\n\nplt.savefig(output_png, dpi=600, bbox_inches=\"tight\", pad_inches=0.05)\nplt.savefig(output_pdf, format=\"pdf\", dpi=600, bbox_inches=\"tight\", pad_inches=0.05)\n\nprint(\"ML scaling plot saved to:\")\nprint(output_png)\nprint(output_pdf)\n\nplt.show()\n```"
