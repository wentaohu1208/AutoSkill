{
  "id": "autoskill-openclaw-adapter",
  "name": "AutoSkill OpenClaw Adapter",
  "description": "Append retrieved skill hints during before_prompt_build and schedule skill evolution after successful runs.",
  "version": "0.1.0",
  "kind": "lifecycle",
  "main": "./index.js",
  "configSchema": {
    "type": "object",
    "properties": {
      "baseUrl": {
        "type": "string",
        "default": "http://127.0.0.1:9100/v1",
        "description": "AutoSkill sidecar base URL."
      },
      "apiKey": {
        "type": "string",
        "default": "",
        "description": "Optional API key for the AutoSkill sidecar."
      },
      "userId": {
        "type": "string",
        "default": "",
        "description": "Optional fixed user id override."
      },
      "skillScope": {
        "type": "string",
        "enum": [
          "all",
          "user",
          "library"
        ],
        "default": "all"
      },
      "skillRetrieval": {
        "type": "object",
        "description": "before_prompt_build retrieval and prompt augmentation settings.",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "topK": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "default": 3
          },
          "maxChars": {
            "type": "integer",
            "minimum": 200,
            "maximum": 8000,
            "default": 1500
          },
          "minScore": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "default": 0.4
          },
          "injectionMode": {
            "type": "string",
            "enum": [
              "appendSystemContext",
              "prependSystemContext"
            ],
            "default": "appendSystemContext"
          }
        },
        "additionalProperties": false
      },
      "topK": {
        "type": "integer",
        "minimum": 1,
        "maximum": 20,
        "default": 3
      },
      "minScore": {
        "type": "number",
        "minimum": 0,
        "maximum": 1,
        "default": 0.4
      },
      "recallEnabled": {
        "type": "boolean",
        "default": false
      },
      "extractOnAgentEnd": {
        "type": "boolean",
        "default": true
      },
      "successOnly": {
        "type": "boolean",
        "default": true
      },
      "includeUserFeedback": {
        "type": "boolean",
        "default": true
      },
      "timeoutMs": {
        "type": "integer",
        "minimum": 500,
        "maximum": 30000,
        "default": 5000
      },
      "retries": {
        "type": "integer",
        "minimum": 0,
        "maximum": 3,
        "default": 1
      },
      "logPayload": {
        "type": "boolean",
        "default": false
      },
      "maxInjectedChars": {
        "type": "integer",
        "minimum": 200,
        "maximum": 8000,
        "default": 1500,
        "description": "Legacy compatibility alias for skillRetrieval.maxChars."
      }
    },
    "additionalProperties": false
  }
}
